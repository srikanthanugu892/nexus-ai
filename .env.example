# === Nexus AI Configuration ===

# API Authentication (shared secret for dev; replace with SSO for prod)
API_KEY=nexus-dev-key-change-me

# LLM (OpenAI-compatible endpoint — works with LiteLLM, Ollama, vLLM, OpenAI direct)
# For OpenAI direct: LITELLM_ENDPOINT=https://api.openai.com/v1
# For LiteLLM proxy: LITELLM_ENDPOINT=http://localhost:4000
# For Ollama:        LITELLM_ENDPOINT=http://localhost:11434/v1
LITELLM_ENDPOINT=https://api.openai.com/v1
LITELLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini

# Embedding model (any OpenAI-compatible embedding endpoint)
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIMENSIONS=1536

# Neo4j (auto-configured by docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus-dev-password

# PostgreSQL + pgvector (auto-configured by docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus_ai
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus-dev-password

# GitHub (for code search MCP and Postman/Bruno collector)
# For github.com: GITHUB_HOST=github.com
# For GitHub Enterprise: GITHUB_HOST=github.yourcompany.com
GITHUB_HOST=github.com
GITHUB_TOKEN=ghp_your-pat-here
GITHUB_ORG=your-org

# Jira & Confluence (Atlassian Cloud)
ATLASSIAN_URL=https://your-org.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
CONFLUENCE_SPACE=ENG

# Vault (HashiCorp — for dynamic DB credentials and service OAuth2)
# Leave empty if not using Vault (live DB queries will be disabled)
VAULT_HOST=vault.example.com
VAULT_TOKEN=
VAULT_ENV=dev
VAULT_TLS_VERIFY=true

# OAuth2 (for service-to-service auth — credentials fetched from Vault at runtime)
AUTH0_ISSUER=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id

# Allowed internal service hosts for live API calls (comma-separated)
# ALLOWED_SERVICE_HOSTS=*.internal.example.com,*.dev.example.com

# === Optional: Per-environment Vault tokens ===
# VAULT_TOKEN_STAGING=
# VAULT_TOKEN_PRODUCTION=

# === Optional: AppRole for fully automated Vault auth (no human login needed) ===
# VAULT_APPROLE_ROLE_ID=
# VAULT_APPROLE_SECRET_ID=
